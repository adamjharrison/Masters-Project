&control
! Input for some model
!------ Initialization -------!
 InitState=1
 InitialCond='NoSample'
 iRndSeed=608145984
!------ Simulation Properties -------!
 Model='TOY'		 ! to identify the potential used
 iMethod=4           ! Indicates GAIMS model
 Grsigma=10.0
 NumParticles=1
 NumStates=2		 ! number of electronic states
 NumSinglets=1
 NumTriplets=1
 zAllText=.true.     ! Output all text-based files
 NumInitBasis=1
!---- Stochastic Selection ----!
 Stochastic = .false.
 StochasticSwiss = .false.
!-------- Integration and numerics --------!
 TimeStep=4.13		    ! = 0.1 fs, timestep for integration
 SimulationTime=15000	! integration time
 MinTimeStep=0.001
!-------- Spawning -------!
!MultiSpawn=1		!number of spawns per event
 MaxTraj=80		    !max number of trajectories
! OMax=0.6
 SpawnCoupV=.false.
 CSThresh=0.0000
 SOCThresh=0.d0
 PopToSpawn=0.000
!CoupTimeStep=0.250
!-------- Output -------!
 zAllText=.false.
 zXYZ=.true.
 zCoupFile=.true.
 zEDatFile=.true.
 zNDatFile=.true.
 zTrajFile=.false.
 zAmpFile=.true.
 zPotEnFile=.true.
 zPCOlap=.true.
 zSOCeff=.true.
 zSOME=.true.
/ !Atom type information below
  1 ! number of atom types
#Name  AtomicNum  AtomicWeight(amu) Width(1/bohr**2)
 QQ    1       10.9700000      20.000000
